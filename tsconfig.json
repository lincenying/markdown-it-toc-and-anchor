{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["ES2018"],
    "rootDir": "src",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/index.ts", "src/types/**/*.d.ts"],
  "exclude": ["src/__tests__"]
}
